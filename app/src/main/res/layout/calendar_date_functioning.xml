<?xml version="1.0" encoding="UTF-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="calendarDateEmptyVM" type="com.pillpal.app.modules.calendardateempty.data.viewmodel.CalendarDateEmptyVM"/>
    </data>

    <LinearLayout
        android:id="@+id/linearColumncar"
        style="@style/groupStylewhite_A700"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="start"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/frameStackcar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_87pxv"
            android:layout_marginTop="@dimen/_20pxh">

            <View
                android:id="@+id/__link_drug_interaction_empty__pillpal_logo"
                android:layout_width="56dp"
                android:layout_height="30dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="@dimen/_19pxh"
                android:background="@drawable/pillpal_logo" />

            <TextView
                android:id="@+id/txtHiIbs"
                style="@style/txtPoppinsregular13"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="@dimen/_19pxh"
                android:layout_marginTop="@dimen/_26pxv"
                android:layout_marginEnd="@dimen/_19pxh"
                android:layout_marginBottom="@dimen/_26pxv"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="@{calendarDateEmptyVM.calendarDateEmptyModel.txtHiIbs}"
                tools:text="@string/lbl_hi_ibs" />

            <TextView
                android:id="@+id/txtLanguage"
                style="@style/txtPoppinssemibold14"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginStart="22dp"
                android:layout_marginEnd="22dp"
                android:layout_marginTop="@dimen/_10pxv"
                android:ellipsize="end"
                android:gravity="top|start"
                android:singleLine="true"
                android:text="@{calendarDateEmptyVM.calendarDateEmptyModel.txtLanguage}"
                tools:text="@string/msg_don_t_forget_to" />
        </FrameLayout>


        <TextView
            android:id="@+id/txtProbiotics"
            style="@style/txtPoppinsbold19"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:layout_marginTop="@dimen/_10pxv"
            android:ellipsize="end"
            android:gravity="top|start"
            android:singleLine="true"
            tools:text="@string/lbl_september_2023" />

            <com.harrywhewell.scrolldatepicker.DayScrollDatePicker
                android:id="@+id/dayDatePicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10pxv"/>

        <FrameLayout
            android:id="@+id/linearRowtotake"
            style="@style/groupStylegreen_1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/_21pxv">

            <LinearLayout
                android:id="@+id/linearColumntotake"
                android:layout_width="match_parent"
                android:layout_height="432dp"
                android:layout_marginStart="@dimen/_20pxh"
                android:layout_marginTop="@dimen/_30pxh"
                android:layout_marginEnd="@dimen/_20pxh"
                android:layout_marginBottom="@dimen/_130pxv"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/txtToTake"
                        style="@style/txtPoppinsbold24"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginEnd="@dimen/_10pxh"
                        android:ellipsize="end"
                        android:text="@{calendarDateEmptyVM.calendarDateEmptyModel.txtToTake}"
                        tools:text="@string/lbl_to_take" />

                    <ImageView
                        android:id="@+id/imagePlus"
                        android:layout_width="@dimen/_31pxh"
                        android:layout_height="@dimen/_31pxh"
                        android:layout_marginLeft="210dp"
                        android:layout_marginTop="5dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_plus_white_a700"
                        tools:ignore="ContentDescription"
                        tools:src="@drawable/img_plus_white_a700" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtNothingHere"
                    style="@style/txtPoppinsbold16"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/_69pxh"
                    android:layout_marginTop="@dimen/_32pxv"
                    android:layout_marginEnd="@dimen/_69pxh"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="@{calendarDateEmptyVM.calendarDateEmptyModel.txtNothingHere}"
                    tools:text="@string/lbl_nothing_here" />

                <ImageView
                    android:id="@+id/imageBbcapcule"
                    android:layout_width="@dimen/_29pxh"
                    android:layout_height="@dimen/_80pxh"
                    android:layout_gravity="bottom|center"
                    android:layout_marginStart="@dimen/_106pxh"
                    android:layout_marginTop="@dimen/_150pxv"
                    android:layout_marginEnd="@dimen/_106pxh"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_bbcapcule_white_a700"
                    tools:ignore="ContentDescription"
                    tools:src="@drawable/img_bbcapcule_white_a700" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/frameNavbar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_57pxv"
                android:layout_gravity="bottom|center">

                <ImageView
                    android:id="@+id/imageSubtract"
                    android:layout_width="@dimen/_360pxh"
                    android:layout_height="@dimen/_57pxh"
                    android:layout_gravity="center"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_subtract"
                    tools:ignore="ContentDescription"
                    tools:src="@drawable/subtract" />

                <LinearLayout
                    android:id="@+id/linearRowuser"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="top|center"
                    android:layout_marginStart="@dimen/_65pxh"
                    android:layout_marginEnd="@dimen/_72pxh"
                    android:layout_marginBottom="@dimen/_10pxv"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imageHome"
                        android:layout_width="@dimen/_29pxh"
                        android:layout_height="@dimen/_25pxh"
                        android:layout_gravity="center"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_home"
                        tools:ignore="ContentDescription"
                        tools:src="@drawable/img_home" />

                    <ImageView
                        android:id="@+id/imageCalendar"
                        android:layout_width="@dimen/_35pxh"
                        android:layout_height="@dimen/_35pxh"
                        android:layout_marginStart="@dimen/_62pxh"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_calendar"
                        tools:ignore="ContentDescription"
                        tools:src="@drawable/img_calendar" />

                    <ImageView
                        android:id="@+id/imageUser"
                        android:layout_width="@dimen/_25pxh"
                        android:layout_height="@dimen/_25pxh"
                        android:layout_marginStart="@dimen/_59pxh"
                        android:layout_marginTop="@dimen/_10pxv"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_user"
                        tools:ignore="ContentDescription"
                        tools:src="@drawable/img_user" />
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>
    </LinearLayout>
    </layout>
