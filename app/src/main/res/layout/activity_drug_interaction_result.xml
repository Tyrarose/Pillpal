<?xml version="1.0" encoding="UTF-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="drugInteractionResultVM" type="com.pillpal.app.modules.druginteractionresult.data.viewmodel.DrugInteractionResultVM"/>
    </data>
    <FrameLayout android:id="@+id/frameDruginteractio"
        android:layout_height="match_parent"
        android:layout_width="match_parent" style="@style/groupStylewhite_A700">
        <View android:background="@color/teal_50"
            android:id="@+id/viewBluebox" android:layout_gravity="start"
            android:layout_height="match_parent" android:layout_width="match_parent"/>
        <LinearLayout android:id="@+id/linearColumnlanguage"
            android:layout_gravity="top|start"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_11pxv"
            android:layout_marginEnd="@dimen/_20pxh"
            android:layout_marginStart="@dimen/_20pxh"
            android:layout_marginTop="@dimen/_11pxv"
            android:layout_width="match_parent" android:orientation="vertical">
            <androidx.appcompat.widget.Toolbar android:gravity="start"
                android:id="@+id/toolbarToolbar"
                android:layout_height="wrap_content"
                android:layout_width="match_parent" app:contentInsetStart="0dp">
                <FrameLayout android:id="@+id/framePillpallogo"
                    android:layout_height="match_parent" android:layout_width="match_parent">
                    <View   android:id="@+id/__link_drug_interaction_empty__pillpal_logo"
                        android:background="@drawable/pillpal_logo"
                        android:layout_width="56dp"
                        android:layout_height="30dp" />
                </FrameLayout>
            </androidx.appcompat.widget.Toolbar>
            <TextView android:ellipsize="end"
                android:layout_gravity="center"
                android:id="@+id/txtPrice"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_20pxh"
                android:layout_marginStart="@dimen/_20pxh"
                android:layout_marginTop="@dimen/_38pxv"
                android:layout_width="match_parent"
                android:lineSpacingExtra="@dimen/_3pxh"
                android:singleLine="true"
                android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtPrice}"
                style="@style/txtRobotoromanbold12" tools:text="@string/msg_add_drug_to_che"/>














            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/lineLineSix"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_20pxv"
                android:layout_marginTop="@dimen/_10pxv"

                android:hint="Tylenol" />





            <FrameLayout android:id="@+id/frameInteraction"
                android:layout_gravity="center"
                android:layout_height="@dimen/_70pxv"
                android:layout_marginEnd="@dimen/_20pxh"
                android:layout_marginStart="@dimen/_20pxh"
                android:layout_marginTop="@dimen/_10pxv"
                android:layout_width="wrap_content" style="@style/groupStylered_300cornerRadius">
                <LinearLayout android:id="@+id/linearColumnwarfarin"
                    android:layout_gravity="start"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_3pxv"
                    android:layout_marginEnd="@dimen/_10pxh"
                    android:layout_marginStart="@dimen/_2pxh"
                    android:layout_marginTop="@dimen/_3pxv"
                    android:layout_width="wrap_content"
                    android:orientation="vertical" style="@style/groupStylewhite_A700cornerRadius">
                    <TextView android:ellipsize="end"
                        android:gravity="start"
                        android:id="@+id/txtWarfarin"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="@dimen/_23pxv"
                        android:layout_marginEnd="@dimen/_29pxh"
                        android:layout_marginStart="@dimen/_29pxh"
                        android:layout_marginTop="@dimen/_21pxv"
                        android:layout_width="match_parent"
                        android:lineSpacingExtra="@dimen/_3pxh"
                        android:singleLine="true"
                        android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtWarfarin}"
                        style="@style/txtRobotoromanbold16" tools:text="@string/lbl_warfarin"/>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/linearColumnacetaminophen"
                    android:layout_gravity="end"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_3pxv"
                    android:layout_marginEnd="@dimen/_3pxh"
                    android:layout_marginStart="@dimen/_10pxh"
                    android:layout_marginTop="@dimen/_3pxv"
                    android:layout_width="wrap_content"
                    android:orientation="vertical" style="@style/groupStylewhite_1">

                </LinearLayout>
                <ImageView android:id="@+id/imageMinimize"
                    android:layout_gravity="center"
                    android:layout_height="@dimen/_19pxh"
                    android:layout_marginBottom="@dimen/_26pxv"
                    android:layout_marginEnd="@dimen/_40pxh"
                    android:layout_marginStart="@dimen/_40pxh"
                    android:layout_marginTop="@dimen/_24pxv"
                    android:layout_width="@dimen/_16pxh"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_minimize"
                    tools:ignore="ContentDescription" tools:src="@drawable/img_minimize"/>
                <FrameLayout android:id="@+id/frameInteraction1"
                    android:layout_gravity="start"
                    android:layout_height="@dimen/_70pxv"
                    android:layout_width="@dimen/_280pxh" style="@style/groupStylered_300cornerRadius">
                    <LinearLayout
                        android:id="@+id/linearColumnwarfarinOne"
                        android:layout_gravity="start"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_3pxv"
                        android:layout_marginEnd="@dimen/_10pxh"
                        android:layout_marginStart="@dimen/_2pxh"
                        android:layout_marginTop="@dimen/_3pxv"
                        android:layout_width="@dimen/_133pxv"
                        android:orientation="vertical" style="@style/groupStylewhite_A700cornerRadius">
                        <TextView android:ellipsize="end"
                            android:gravity="center"
                            android:id="@+id/txtWarfarinOne"
                            android:layout_height="match_parent"
                            android:layout_marginBottom="@dimen/_21pxv"
                            android:layout_marginEnd="@dimen/_26pxh"
                            android:layout_marginStart="@dimen/_26pxh"
                            android:layout_marginTop="@dimen/_19pxv"
                            android:layout_width="match_parent"
                            android:lineSpacingExtra="@dimen/_8pxh"
                            android:singleLine="true"
                            android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtWarfarinOne}"
                            style="@style/txtPoppinsbold15_1" tools:text="@string/lbl_warfarin"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/linearColumnacetaminophenOne"
                        android:layout_gravity="end"

                        android:ellipsize="none"
                        android:breakStrategy="simple"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_3pxv"
                        android:layout_marginEnd="@dimen/_3pxh"
                        android:layout_marginStart="@dimen/_10pxh"
                        android:layout_marginTop="@dimen/_3pxv"
                        android:layout_width="@dimen/_133pxv"
                        android:orientation="vertical" style="@style/groupStylewhite_1">
                        <TextView android:gravity="center"
                            android:id="@+id/txtAcetaminophenOne"
                            android:layout_height="match_parent"
                            android:layout_marginBottom="@dimen/_9pxv"
                            android:layout_marginEnd="@dimen/_1pxh"
                            android:layout_marginStart="@dimen/_11pxh"
                            android:layout_marginTop="@dimen/_12pxv"
                            android:layout_width="match_parent"
                            android:lineSpacingExtra="@dimen/_2pxh"
                            android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtAcetaminophenOne}"
                            style="@style/txtPoppinsbold15_1" tools:text="@string/msg_acetaminophen"/>
                    </LinearLayout>
                    <ImageView android:id="@+id/imageMinimizeOne"
                        android:layout_gravity="center"
                        android:layout_height="@dimen/_19pxh"
                        android:layout_marginBottom="@dimen/_26pxv"
                        android:layout_marginEnd="@dimen/_40pxh"
                        android:layout_marginStart="@dimen/_40pxh"
                        android:layout_marginTop="@dimen/_24pxv"
                        android:layout_width="@dimen/_16pxh"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_minimize"
                        tools:ignore="ContentDescription" tools:src="@drawable/img_minimize"/>
                </FrameLayout>
            </FrameLayout>
            <LinearLayout android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/linearRowseverity"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_91pxh"
                android:layout_marginStart="@dimen/_91pxh"
                android:layout_marginTop="@dimen/_24pxv"
                android:layout_width="wrap_content" android:orientation="horizontal">
                <FrameLayout android:id="@+id/frameStackseverity"
                    android:layout_height="wrap_content" android:layout_width="wrap_content">
                    <TextView android:ellipsize="end"
                        android:gravity="top|start"
                        android:id="@+id/txtSEVERITY"
                        android:layout_gravity="start"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:lineSpacingExtra="@dimen/_3pxh"
                        android:singleLine="true"
                        android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtSEVERITY}"
                        style="@style/txtRobotoromanbold15" tools:text="@string/lbl_severity"/>
                    <TextView android:ellipsize="end"
                        android:gravity="top|start"
                        android:id="@+id/txtSEVERITYOne"
                        android:layout_gravity="start"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:lineSpacingExtra="@dimen/_3pxh"
                        android:singleLine="true"
                        android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtSEVERITYOne}"
                        style="@style/txtRobotoromanbold15_1" tools:text="@string/lbl_severity"/>
                </FrameLayout>
                <ImageView android:id="@+id/imageQuestion"
                    android:layout_height="@dimen/_14pxh"
                    android:layout_marginBottom="@dimen/_1pxv"
                    android:layout_marginStart="@dimen/_2pxh"
                    android:layout_marginTop="@dimen/_2pxv"
                    android:layout_width="@dimen/_14pxh"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_question_white_a700"
                    tools:ignore="ContentDescription" tools:src="@drawable/img_question_white_a700"/>
            </LinearLayout>
            <FrameLayout android:id="@+id/frameModerate"
                android:layout_gravity="center"
                android:layout_height="@dimen/_30pxv"
                android:layout_marginEnd="@dimen/_84pxh"
                android:layout_marginStart="@dimen/_84pxh"
                android:layout_marginTop="@dimen/_5pxv"
                android:layout_width="@dimen/_115pxh" style="@style/groupStylered_300cornerRadius">
                <TextView android:ellipsize="end"
                    android:gravity="top|start"
                    android:id="@+id/txtMODERATE"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_6pxv"
                    android:layout_marginEnd="@dimen/_24pxh"
                    android:layout_marginStart="@dimen/_25pxh"
                    android:layout_marginTop="@dimen/_5pxv"
                    android:layout_width="match_parent"
                    android:lineSpacingExtra="@dimen/_6pxh"
                    android:singleLine="true"
                    android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtMODERATE}"
                    style="@style/txtPoppinsbold12" tools:text="@string/lbl_moderate"/>
                <androidx.appcompat.widget.AppCompatButton
                    android:ellipsize="end" android:gravity="center"
                    android:id="@+id/btnModerateOne"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:lineSpacingExtra="@dimen/_6pxh"
                    android:paddingBottom="@dimen/_6pxv"
                    android:paddingEnd="@dimen/_24pxh"
                    android:paddingStart="@dimen/_25pxh"
                    android:paddingTop="@dimen/_6pxv"
                    android:singleLine="true"
                    android:text="@string/lbl_moderate"
                    android:textAllCaps="false"
                    style="@style/btnSolidRounded_5" tools:text="@string/lbl_moderate"/>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout android:id="@+id/linearColumnpriceSeven"
            android:layout_gravity="center"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_168pxv"
            android:layout_marginEnd="@dimen/_42pxh"
            android:layout_marginStart="@dimen/_42pxh"
            android:layout_marginTop="@dimen/_300pxv"
            android:layout_width="match_parent" android:orientation="vertical">
            <TextView android:ellipsize="end"
                android:id="@+id/txtPriceSeven"
                android:layout_gravity="center_horizontal"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_55pxh"
                android:layout_marginStart="@dimen/_55pxh"
                android:layout_marginTop="@dimen/_4pxv"
                android:layout_width="wrap_content"
                android:lineSpacingExtra="@dimen/_3pxh"
                android:singleLine="true"
                android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtPriceSeven}"
                style="@style/txtRobotoromanbold15_1" tools:text="@string/lbl_description"/>
            <TextView android:gravity="center_horizontal"
                android:id="@+id/txtDescriptionSix"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_1pxh"
                android:layout_marginTop="@dimen/_5pxv"
                android:layout_width="match_parent"
                android:lineSpacingExtra="@dimen/_3pxh"
                android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtDescriptionSix}"
                style="@style/txtInterregular12" tools:text="@string/msg_lorem_ipsum_dol"/>
            <TextView android:ellipsize="end"
                android:gravity="center_horizontal"
                android:id="@+id/txtPriceEight"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_52pxh"
                android:layout_marginStart="@dimen/_55pxh"
                android:layout_marginTop="@dimen/_23pxv"
                android:layout_width="match_parent"
                android:lineSpacingExtra="@dimen/_3pxh"
                android:singleLine="true"
                android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtPriceEight}"
                style="@style/txtRobotoromanbold15_1" tools:text="@string/msg_extended_descri"/>
            <TextView android:gravity="center_horizontal"
                android:id="@+id/txtDescriptionSeven"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_1pxh"
                android:layout_marginTop="@dimen/_5pxv"
                android:layout_width="match_parent"
                android:lineSpacingExtra="@dimen/_3pxh"
                android:text="@{drugInteractionResultVM.drugInteractionResultModel.txtDescriptionSeven}"
                style="@style/txtInterregular12" tools:text="@string/msg_lorem_ipsum_dol2"/>
        </LinearLayout>
        <FrameLayout android:id="@+id/frameNavbar"
            android:layout_gravity="bottom|start"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_10pxv" android:layout_width="match_parent">
            <ImageView android:id="@+id/imageSubtract"
                android:layout_gravity="start"
                android:layout_height="@dimen/_57pxh"
                android:layout_width="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/img_subtract"
                tools:ignore="ContentDescription" tools:src="@drawable/img_subtract"/>
            <LinearLayout android:id="@+id/linearRowuser"
                android:layout_gravity="top|center"
                android:layout_height="match_parent"
                android:layout_marginBottom="@dimen/_10pxv"
                android:layout_marginEnd="@dimen/_72pxh"
                android:layout_marginStart="@dimen/_65pxh"
                android:layout_width="wrap_content" android:orientation="horizontal">
                <ImageView android:id="@+id/imageHome"
                    android:layout_gravity="center"
                    android:layout_height="@dimen/_35pxh"
                    android:layout_marginBottom="@dimen/_5pxv"
                    android:layout_width="@dimen/_40pxh"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_home"
                    tools:ignore="ContentDescription"
                    tools:src="@drawable/img_home"/>
                <ImageView android:id="@+id/imageCalendar"
                    android:layout_height="@dimen/_25pxh"
                    android:layout_marginStart="@dimen/_57pxh"
                    android:layout_marginTop="@dimen/_15pxv"
                    android:layout_width="@dimen/_22pxh"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_calendar"
                    tools:ignore="ContentDescription" tools:src="@drawable/img_calendar"/>
                <ImageView android:id="@+id/imageUser"
                    android:layout_height="@dimen/_25pxh"
                    android:layout_marginStart="@dimen/_59pxh"
                    android:layout_marginTop="@dimen/_16pxv"
                    android:layout_width="@dimen/_25pxh"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_user"
                    tools:ignore="ContentDescription" tools:src="@drawable/img_user"/>
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>
</layout>
