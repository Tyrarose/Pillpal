<?xml version="1.0" encoding="UTF-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="welcomeVM" type="com.pillpal.app.modules.welcome.data.viewmodel.WelcomeVM"/>
    </data>
    <LinearLayout android:gravity="center_horizontal"
        android:id="@+id/linearWelcome"
        android:layout_height="match_parent"
        android:layout_width="match_parent"
        android:orientation="vertical" style="@style/groupStylewhite_A700">
        <LinearLayout android:gravity="start"
            android:id="@+id/linearColumngroup"
            android:layout_height="match_parent"
            android:layout_width="match_parent"
            android:orientation="vertical" style="@style/groupStyleteal_100">
            <LinearLayout android:id="@+id/linearRowgroup"
                android:layout_height="wrap_content"
                android:layout_width="match_parent" android:orientation="horizontal">
                <ImageView android:id="@+id/imageGroup"
                    android:layout_height="@dimen/_112pxh"
                    android:layout_marginBottom="@dimen/_64pxv"
                    android:layout_marginTop="@dimen/_88pxv"
                    android:layout_width="@dimen/_81pxh"
                    android:scaleType="fitXY"
                    imageRes="@{@drawable/img_group}"
                    tools:ignore="ContentDescription" tools:src="@drawable/img_group"/>
                <LinearLayout android:id="@+id/linearColumngroupOne"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_129pxh"
                    android:layout_weight="0.65"
                    android:layout_width="0dp" android:orientation="vertical">
                    <ImageView android:id="@+id/imageGroupOne"
                        android:layout_gravity="end"
                        android:layout_height="@dimen/_94pxh"
                        android:layout_marginStart="@dimen/_10pxh"
                        android:layout_width="@dimen/_62pxh"
                        android:scaleType="fitXY"
                        imageRes="@{@drawable/img_group_white_a700}"
                        tools:ignore="ContentDescription" tools:src="@drawable/img_group_white_a700"/>
                    <ImageView android:id="@+id/imageGroupTwo"
                        android:layout_gravity="start"
                        android:layout_height="@dimen/_107pxh"
                        android:layout_marginEnd="@dimen/_10pxh"
                        android:layout_marginTop="@dimen/_62pxv"
                        android:layout_width="@dimen/_116pxh"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_group_white_a700_107x116"
                        tools:ignore="ContentDescription" tools:src="@drawable/img_group_white_a700_107x116"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:id="@+id/linearRowcheckmark"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_57pxv"
                android:layout_marginTop="@dimen/_11pxv"
                android:layout_width="match_parent" android:orientation="horizontal">
                <LinearLayout android:id="@+id/linearColumniconmedici"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.9"
                    android:layout_width="0dp" android:orientation="vertical">
                    <LinearLayout android:id="@+id/linearRowiconmedici"
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent" android:orientation="horizontal">
                        <ImageView android:id="@+id/imageIconmedici"
                            android:layout_height="@dimen/_70pxh"
                            android:layout_marginBottom="@dimen/_1pxv"
                            android:layout_marginTop="@dimen/_121pxv"
                            android:layout_width="@dimen/_51pxh"
                            android:scaleType="fitXY"
                            imageRes="@{@drawable/img_iconmedici}"
                            tools:ignore="ContentDescription" tools:src="@drawable/img_iconmedici"/>
                        <LinearLayout
                            android:gravity="center_horizontal"
                            android:id="@+id/linearColumnlanguage"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_1pxh"
                            android:layout_weight="0.84"
                            android:layout_width="0dp" android:orientation="vertical">
                            <TextView android:ellipsize="end"
                                android:gravity="start"
                                android:id="@+id/txtLanguage"
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:singleLine="true"
                                android:text="@{welcomeVM.welcomeModel.txtLanguage}"
                                style="@style/txtPoppinsbold40" tools:text="@string/lbl_hi_i_m_pillpal"/>
                            <ImageView android:id="@+id/imageBbcapcule"
                                android:layout_gravity="center_horizontal"
                                android:layout_height="@dimen/_104pxh"
                                android:layout_marginEnd="@dimen/_112pxh"
                                android:layout_marginStart="@dimen/_113pxh"
                                android:layout_marginTop="@dimen/_27pxv"
                                android:layout_width="@dimen/_35pxh"
                                android:scaleType="fitXY"
                                android:src="@drawable/img_bbcapcule"
                                tools:ignore="ContentDescription" tools:src="@drawable/img_bbcapcule"/>
                        </LinearLayout>
                    </LinearLayout>
                    <ImageView android:id="@+id/imageCheckmark"
                        android:layout_gravity="start"
                        android:layout_height="@dimen/_82pxh"
                        android:layout_marginEnd="@dimen/_94pxh"
                        android:layout_marginStart="@dimen/_94pxh"
                        android:layout_marginTop="@dimen/_163pxv"
                        android:layout_width="@dimen/_82pxh"
                        android:scaleType="fitXY"
                        android:src="@drawable/img_checkmark"
                        tools:ignore="ContentDescription" tools:src="@drawable/img_checkmark"/>
                </LinearLayout>
                <ImageView android:id="@+id/imageMedicinesdrug"
                    android:layout_height="@dimen/_71pxh"
                    android:layout_marginBottom="@dimen/_118pxv"
                    android:layout_marginStart="@dimen/_10pxh"
                    android:layout_marginTop="@dimen/_248pxv"
                    android:layout_width="@dimen/_36pxh"
                    android:scaleType="fitXY"
                    android:src="@drawable/img_medicinesdrug"
                    tools:ignore="ContentDescription" tools:src="@drawable/img_medicinesdrug"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</layout>
